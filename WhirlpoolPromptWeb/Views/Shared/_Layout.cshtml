<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WhirlpoolPromptWeb</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WhirlpoolPromptWeb.styles.css" asp-append-version="true" />
</head>

<body>
    <header>
        <nav
            class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3 px-5">
            <div class="container-xl mx-auto">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <img class="whirlpool-logo" src="~/images/logo-whirlpool.png" alt="Whirlpool Logo" />
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent" aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <button class="btn btn-light bg-white border-0" asp-area="" asp-controller="Home"
                                    asp-action="Index">
                                Inicio
                            </button>
                        </li>
                        <li class="nav-item dropdown">
                            <button class="btn btn-light bg-transparent border-0 dropdown-toggle"
                                    data-bs-toggle="dropdown" aria-expanded="false">Prompts
                            </button>
                            <ul class="dropdown-menu dropdown-menu-light">
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Home"
                                           asp-action="CreatePrompt">
                                        Crear Prompt
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="Library">
                                        Biblioteca
                                    </a>
                                </li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <button class="btn btn-light bg-white border-0" asp-area="" asp-controller="Home"
                                    asp-action="Leaderboard">
                                Clasificación
                            </button>
                        </li>
                    </ul>
                </div>
                <div class="ml-auto">
                    <a href="" class="coins-cont">
                        <img src="~/images/moneda-nueva.png" alt="Monedas" />
                        <span>@ViewData["Coins"]</span>
                    </a>
                </div>
                <div class="ml-3">
                    <a asp-area="" asp-controller="Home" asp-action="Profile">
                        <img class="nav-profile-photo" src="~/images/@ViewData["ProfilePhoto"]" alt="Perfil" />
                    </a>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Whirlpool - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
